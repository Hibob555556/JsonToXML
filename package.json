{
  "name": "TypescriptAutodoc",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "husky",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "test": "vitest --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts --watch",
    "test:coverage": "vitest --config vitest.unit.config.ts --coverage",
    "test:unit": "vitest --config vitest.unit.config.ts",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.15.2",
    "nuxt": "^4.4.2",
    "vue": "^3.5.31"
  },
  "overrides": {
    "@emnapi/core": "1.9.2",
    "@emnapi/runtime": "1.9.2",
    "crossws": "0.4.4"
  },
  "devDependencies": {
    "@emnapi/core": "1.9.2",
    "@emnapi/runtime": "1.9.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.38.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "vitest": "^4.1.2"
  }
}
